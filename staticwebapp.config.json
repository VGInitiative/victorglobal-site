{
  "routes": [
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated", "administrator"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated", "administrator"]
    }
  ],
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, POST, OPTIONS"
  },
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    },
    "403": {
      "redirect": "/index.html",
      "statusCode": 302
    }
  }
}